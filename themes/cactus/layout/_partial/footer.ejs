<footer id="footer">
  <%
    var footerLang = page.lang ? String(page.lang).substring(0, 2) : 'fr';
    if (!page.lang) {
      if (Array.isArray(config.language) && config.language[0]) {
        footerLang = String(config.language[0]).substring(0, 2);
      } else if (config.language) {
        footerLang = String(config.language).substring(0, 2);
      }
    }
    function footerNavHref(u) {
      if (/^https?:\/\//.test(u)) return u;
      if (u === '/archives/') return '/' + footerLang + '/';
      return '/' + footerLang + (u === '/' ? '/' : u);
    }
  %>
  <div class="footer-left">
    <%= __('footer.copyright') %> &copy;
    <% var endYear = (theme.copyright && theme.copyright.end_year) ? theme.copyright.end_year : new Date().getFullYear() %>
    <% var startYear = (theme.copyright && theme.copyright.start_year) ? theme.copyright.start_year : new Date().getFullYear() %>
    <%= startYear >= endYear ? endYear : startYear + "-" + endYear %>
    <%= config.author || config.title %>
  </div>
  <div class="footer-right">
    <nav>
      <ul>
        <% for (var i in theme.nav) { %><!--
       --><li><a href="<%- url_for(footerNavHref(theme.nav[i])) %>"><%= __('nav.'+i).replace("nav.", "") %></a></li><!--
     --><% } %>
      </ul>
    </nav>
  </div>
</footer>
