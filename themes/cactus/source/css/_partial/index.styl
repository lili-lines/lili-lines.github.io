.post-list
  padding: 0

  .post-item
    margin-bottom: 1rem
    margin-left: 0
    list-style-type: none

    .meta
      display: block
      margin-right: 16px
      min-width: 100px
      color: $color-meta
      font-size: 14px

@media (min-width: 480px)
  .post-list
    .post-item
      display: flex
      margin-bottom: 5px

      .meta
        text-align: left

.post-gallery
  display: grid
  grid-template-columns: 1fr
  gap: 1.5rem
  list-style: none

  .post-item
    margin: 0
    display: block

  .post-thumb
    display: block
    margin-bottom: 0.5rem
    background: none
    text-decoration: none

    &:hover
      background: none

    img
      width: 100%
      height: 180px
      object-fit: cover
      border-radius: 4px

  .post-meta-row
    display: flex
    flex-direction: row
    align-items: baseline
    justify-content: space-between
    width: 100%
    text-align: left

  .post-title
    display: block
    background: none
    text-decoration: none
    text-align: left
    min-width: 0
    flex: 1 1 auto

    &:hover
      background: none

  .post-item .meta
    margin: 0
    min-width: 0
    margin-right: 0
    text-align: right
    white-space: normal
    overflow-wrap: anywhere
    flex-shrink: 1

@media (min-width: 640px)
  .post-gallery
    grid-template-columns: repeat(2, minmax(0, 1fr))

@media (min-width: 960px)
  .post-gallery
    grid-template-columns: repeat(3, minmax(0, 1fr))

.project-list
  padding: 0
  list-style: none

  .project-item
    margin-bottom: 5px
    p
      display: inline
